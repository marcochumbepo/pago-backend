# .env.example - Template de variables requeridas. Copiar a .env y ajustar valores.
# No contiene secretos reales.

Database__Provider=InMemory
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=UsersDb;User Id=sa;Password=TU_PASSWORD;TrustServerCertificate=True;
MSSQL_SA_PASSWORD=TU_PASSWORD
ASPNETCORE_ENVIRONMENT=Development
